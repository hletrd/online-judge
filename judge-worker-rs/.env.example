# Judge worker configuration
# Copy this file to .env and fill in the values.

# URL to poll for pending submissions (default: http://localhost:3000/api/v1/judge/poll)
JUDGE_POLL_URL=http://localhost:3000/api/v1/judge/poll

# Shared secret between the web app and this worker (required, min 32 chars)
# Generate with: openssl rand -hex 32
JUDGE_AUTH_TOKEN=your-judge-auth-token

# Polling interval in milliseconds (default: 2000)
POLL_INTERVAL=2000

# Maximum concurrent submissions to judge (1–16, default: 1)
JUDGE_CONCURRENCY=1

# Path to the Docker seccomp profile used during the run phase
# (default: ./docker/seccomp-profile.json)
# JUDGE_SECCOMP_PROFILE=./docker/seccomp-profile.json

# Set to 1/true/yes/on to disable the custom seccomp profile (reduces sandboxing — dev only)
# JUDGE_DISABLE_CUSTOM_SECCOMP=false

# Directory where failed result payloads are written as JSON for manual recovery.
# When all 3 report retries are exhausted the judge result is saved here instead of
# being silently discarded, so the submission can be replayed without re-judging.
# (default: ./dead-letter)
# DEAD_LETTER_DIR=./dead-letter
