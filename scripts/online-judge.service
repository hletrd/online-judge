[Unit]
Description=Online Judge Next.js App
After=network.target docker.service postgresql.service
Wants=postgresql.service
OnFailure=notify-failure@%n.service

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/judgekit
Environment=NODE_ENV=production
EnvironmentFile=/home/ubuntu/judgekit/.env
ExecStart=/usr/bin/npm start -- -H 127.0.0.1 -p 3000
Restart=always
RestartSec=5
# Security hardening
ProtectSystem=strict
ProtectHome=read-only
PrivateTmp=true
NoNewPrivileges=true
ReadWritePaths=/home/ubuntu/judgekit/data
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectControlGroups=true
RestrictSUIDSGID=true
CapabilityBoundingSet=
RestrictNamespaces=true
RestrictRealtime=true
LockPersonality=true
SystemCallArchitectures=native
MemoryMax=2G
CPUQuota=200%

[Install]
WantedBy=multi-user.target
