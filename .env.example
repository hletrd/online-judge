# =============================================================================
# JudgeKit Environment Variables
# Copy to .env and fill in required values.
# =============================================================================

# --- App Runtime ---

# Auth
AUTH_SECRET=your-secret-key-here-generate-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3000
# Set to true only behind a trusted reverse proxy or for isolated local automation.
AUTH_TRUST_HOST=false
# Required for plugin secret storage and API key encryption
PLUGIN_CONFIG_ENCRYPTION_KEY=generate-with-openssl-rand-hex-32

# Database
# Current runtime: PostgreSQL
DB_DIALECT=postgresql
# PostgreSQL connection string
DATABASE_URL=postgres://judgekit:judgekit@localhost:5432/judgekit

# Rate Limiting
RATE_LIMIT_MAX_ATTEMPTS=5
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_BLOCK_MS=900000
SUBMISSION_RATE_LIMIT_MAX_PER_MINUTE=5
SUBMISSION_MAX_PENDING=3
SUBMISSION_GLOBAL_QUEUE_LIMIT=100

# Compiler sandbox workspace (Docker-in-Docker only)
# Set to a host-mounted path so sibling containers can access workspace files.
# Not needed for local development (defaults to os.tmpdir()).
# COMPILER_WORKSPACE_DIR=/compiler-workspaces

# Realtime/SSE coordination
# Supported modes:
#   - process-local mode: declare APP_INSTANCE_COUNT=1 (or REALTIME_SINGLE_INSTANCE_ACK=1)
#   - shared PostgreSQL mode: set REALTIME_COORDINATION_BACKEND=postgresql
APP_INSTANCE_COUNT=1
# REALTIME_SINGLE_INSTANCE_ACK=1
# REALTIME_COORDINATION_BACKEND=postgresql

# Code Similarity (Rust sidecar)
CODE_SIMILARITY_URL=http://127.0.0.1:3002

# Judge Worker
# Preferred: set JUDGE_BASE_URL (claim and report URLs are derived automatically)
JUDGE_BASE_URL=http://localhost:3000/api/v1
# Legacy: JUDGE_POLL_URL is still supported for backward compatibility
# JUDGE_POLL_URL=http://localhost:3000/api/v1/judge/poll
JUDGE_AUTH_TOKEN=generate-with-openssl-rand-hex-32
POLL_INTERVAL=2000
JUDGE_DISABLE_CUSTOM_SECCOMP=0
# Max concurrent submissions to judge in parallel (1-16, default: 1)
JUDGE_CONCURRENCY=1
# Hostname reported to the app server during worker registration (default: system hostname)
# JUDGE_WORKER_HOSTNAME=worker-1

# --- Deployment Targets ---

# Target 1: TEST / STAGING
TEST_HOST=
TEST_DOMAIN=
TEST_ARCH=amd64
TEST_SSH_USER=
TEST_SSH_PASSWORD=
TEST_REMOTE_DIR=
TEST_APP_PORT=3100
TEST_WEB_ADMIN_USER=admin
TEST_WEB_ADMIN_PASSWORD=

# Target 2: PRODUCTION
PROD_DOMAIN=
PROD_ARCH=arm64
PROD_SSH_USER=
PROD_SSH_KEY=
PROD_REMOTE_DIR=
PROD_APP_PORT=3100
PROD_WEB_ADMIN_USER=admin
PROD_WEB_ADMIN_PASSWORD=

# E2E Test (against test server)
E2E_TEST_BASE_URL=
E2E_TEST_USERNAME=
E2E_TEST_PASSWORD=

# E2E Test (against production)
E2E_PROD_BASE_URL=
E2E_PROD_USERNAME=
E2E_PROD_PASSWORD=
