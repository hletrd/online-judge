FROM debian:bookworm-slim

RUN apt-get update && \
    apt-get install -y --no-install-recommends gfortran && \
    rm -rf /var/lib/apt/lists/* && \
    useradd --create-home --shell /usr/sbin/nologin judge && \
    mkdir -p /workspace && \
    chown judge:judge /workspace

WORKDIR /workspace
USER judge
